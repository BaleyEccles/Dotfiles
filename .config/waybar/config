
{
"gtk-layer-shell": true,
"layer": "top",
"position": "top",
    "height": 10,
    "spacing": 3,
    "margin-top": 0,
    "margin-bottom":0,

    // Choose the order of the modules
    "modules-left":["custom/power", "custom/refreshrate", "backlight", "pulseaudio", "custom/zypper", "memory", "cpu", "temperature"],
    "modules-center": ["custom/media", "custom/launcher", "hyprland/workspaces", "wlr/taskbar"],
    "modules-right":["custom/gpu_temp", "custom/gpu_usage", "battery", "battery#bat2", "network", "tray",  "clock"],
    // Modules configuration

    //need nvidia driver I cannot be bothered atm
    "custom/gpu_usage": {
        "tooltip": false,
	"format": "{}% ´őŤ",
	"interval": 1,
	"exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv | grep -G [0-9] -o",
    	"exec-if": "exit 0"
    },
    "custom/gpu_temp": {
        "tooltip": true,
	"format": " {}┬░C ",
	"interval": 10,
	"exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv | grep -G [0-9] -o | tr -d '\n'",
    	"exec-if": "exit 0"
    },
    "custom/power": {
        "tooltip": false,
	"format": "{}",
	"interval": 1,
	"exec": "asusctl profile -p | grep -E 'Q|B|P' -o",
    	"exec-if": "exit 0",
        "on-click": "asusctl profile -n"
	},
	"custom/refreshrate": {
        "tooltip": false,
	"format": "{} Hz",
	"interval": 2,
	"exec": "hyprctl monitors | grep -E '120.0|60.0' -o | grep -E '120|60' -o",
    	"exec-if": "exit 0",
	"on-click": "hyprctl monitors | grep -F -o 60 &&  hyprctl keyword monitor ,1920x1200@120,auto,1 ||  hyprctl keyword monitor ,1920x1200@60,auto,1"
	},


    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "´äť {name} {icon}",
        "format-icons": {
            "locked": "´Çú",
            "unlocked": "´éť"
        }
    },
     "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 20,
        "icon-theme": "Star",
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "on-click-right": "activate"
    },
   "sway/language": {
    "format": "´äť {}",
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        }
    },
    "tray": {
        "icon-size": 20,
        "spacing": 10
    },
    "clock": {
        "timezone": "Australia/Hobart",
        "format": "{:%a %d %m %Y  %r}",
	"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
	"interval": 1
    },
    "cpu": {
        "format": "{usage}% ´őŤ",
        "tooltip": false
    },
    "memory": {
        "format": "{}%"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C",
        "format": "{temperatureC}┬░C"
    },
    "backlight": {
        "format": "{percent}% {icon}",
        "format-icons": ["´ćů", "´äĹ"]
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% {icon}",
        "format-charging": "{capacity}% ´Śž",
        "format-plugged": "{capacity}% ´çŽ",
        "format-alt": "{time} {icon}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "{essid} ({signalStrength}%) ´çź",
        "format-ethernet": "Connected ´âü ",
        "tooltip-format": "{ifname} via {gwaddr} ´×ľ",
        "format-linked": "{ifname} (No IP) ´×ľ",
        "format-disconnected": "Disconnected ÔÜá",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "on-click-right": "kitty nmtui"

    },
    "pulseaudio": {
        "format": "{volume}% {icon}",
        "format-bluetooth": "{volume}% {icon}´Őö",
        "format-bluetooth-muted": "{icon}´Őö {format_source}",
        "format-muted": "{format_source}",
        "format-source": "´ÇŽ",
        "format-source-muted": "´ä▒",
        "format-icons": {
            "headphone": "´Çą",
            "hands-free": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "  {}  ",
        "return-type": "json",
	"max-length": 20,
        "escape": true,
        "exec": "/usr/bin/python3 $HOME/.config/waybar/custom_modules/mediaplayer.py --player spotify",
        "on-click": "playerctl play-pause"
    },
    "custom/launcher":{
        "format": " ´čľ ",
        "on-click": "wofi --show drun --location 1",
        "on-click-right": "killall wofi"
    }
}
