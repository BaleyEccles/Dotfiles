{
    "layer": "top", // Waybar at top layer
    // "position": "bottom", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // "gtk-layer-shell": "false",
    // Choose the order of the modules
    "modules-left": ["hyprland/workspaces", "custom/scratchpad", "tray"],
//    "modules-center": ["hyprland/window"],
    "modules-right": ["custom/zypper", "network", "memory", "cpu", "temperature", "custom/gpu", "custom/gputemp", "backlight","custom/power", "battery", "battery#bat2", "pulseaudio", "custom/layout", "clock", "custom/notification"],
    "sway/mode": {
        "format": "´üö´äů {}"
    },
    "hyprland/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "format": " {icon} ",
        "format-icons": {
            "urgent": "´čľ",
            "focused": "´čľ",
            "default": "´čľ"
        }
    },
    "sway/window": {
        "max-length": 80,
        "tooltip": false
    },
    "custom/layout": {
        "tooltip": false,
        "exec": "swaymsg -mrt subscribe '[\"input\"]' | jq -r --unbuffered \"select(.change == \\\"xkb_layout\\\") | .input | select(.type == \\\"keyboard\\\") | .xkb_active_layout_name | .[0:2]\""
    },
    "custom/zypper": {
        "format": "{} ´ćç",
        "interval": 3600,
        "exec": "zypper lu | grep 'v |' | wc -l; echo 'packages to update'",
        "exec-if": "exit 0",
        "on-click": "exec alacritty -e sudo sh -c 'zypper ref; zypper dup; pkill -SIGRTMIN+8 waybar'",
        "signal": 8
    },
    // Modules configuration
      "hyprland/workspaces": {
         "disable-scroll": true,
         "all-outputs": true,
         "format": "{name}: {icon}",
	 // ´äí,´ć╝,´ëĘ,´ëĘ,´ëž,´ëŽ,´ëą,´ëĄ,´ëú,´ëŻ,´äí,´äá,´üÁ,´ü¬,´ćĺ,´äĹ,´Äč,´Çë,´ëĘ,´ëę,´ë¬,´ë¬,´ëź
         "format-icons": {
             "1": "´čľ",
             "2": "´čľ",
             "3": "´čľ",
	     "4": "´čľ",
	     "5": "´čľ",
	     "6": "´čľ",
	     "7": "´čľ",
	     "8": "´čľ",
	     "9": "´čľ",
	     "10": "´čľ",
             "urgent": "´ü¬",
             "focused": "´ćĺ",
             "default": "´äĹ"
         }
     },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "´ü«",
            "deactivated": "´ü░"
        } 
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "timezone": "Australia/Hobart",
        "format": "´ÇŚ {:%a %d %m %Y  %r}",
        "tooltip-format": "<span color='#35b9ab'><big>{:%Y %B}</big></span>\n<span color='#35b9ab'><tt><small>{calendar}</small></tt></span>",
        "format-alt": "{:%a %d %b w:%V %H:%M}",
        "today-format": "<span color='#21a4df'><b><u>{}</u></b></span>",
        "calendar-weeks-pos": "left",
        "format-calendar": "<span background='#173f4f' bgalpha='60%'><b>{}</b></span>",
        "format-calendar-weeks": "<span color='#73ba25'><b>{}</b></span>",
        "format-calendar-weekdays": "<span color='#21a4df'><b>{}</b></span>",
        "interval": 1
    },
    "cpu": {
        "format": "CPU: {usage}% ´őŤ",
	"interval": 10,
	"tooltip": false
    },
    "memory": {
        "format": "{}% ´âë"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": ["´Łź", "´őë", "´Łę"]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-icons": ["´ćů", "´äĹ"]
    },
    "battery": {
    	"interval": 2,
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": "´Śž",
        "format-plugged": "´çŽ",
        "format-alt": "{capacity}% {time}",
        "format-icons": ["´ëä", "´ëâ", "´ëé", "´ëü", "´ëÇ"]
    },
    "battery#bat2": {
        "bat": "BAT2",
	"interval": 2
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        "format-wifi": "´çź",
        "format-ethernet": "´Ť┐",
        "format-linked": "´×ľ",
        "format-disconnected": "ÔÜá",
        "format-alt": "{ifname} {essid} ({signalStrength}%)"
    },
    "pulseaudio": {
        "format": "{icon}",
        "format-alt": "{volume} {icon}",
        "format-alt-click": "click-right",
        "format-muted": "´Üę",
        "format-icons": {
            "headphones": "´Çą",
            "handsfree": "´ľÉ",
            "headset": "´ľÉ",
            "phone": "´éĽ",
            "portable": "´éĽ",
            "car": "´ć╣",
            "default": ["´ÇŽ", "´Çž", "´ÇĘ"]
        },
        "scroll-step": 10,
        "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right": "pavucontrol",
        "tooltip": false
    },
    "custom/scratchpad": {
        "format-text": "{}",
        "return-type": "json",
        "interval": 3,
        "exec": "/usr/share/openSUSEway/helpers/scratchpad-indicator.sh 2> /dev/null",
        "exec-if": "exit 0",
        "on-click": "swaymsg 'scratchpad show'",
        "on-click-right": "swaymsg 'move scratchpad'"
    },
    "custom/notification": {
	"tooltip": true,
	"format": "{icon}",
	"format-icons": {
	     "notification": "´éó<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
	     "none": "´éó ",
	     "dnd-notification": "´çĚ<span foreground='red'><small><sup>ÔČĄ</sup></small></span>",
	     "dnd-none": "´çĚ "
	},
	"return-type": "json",
	"exec-if": "which swaync-client",
	"exec": "swaync-client -swb",
	"on-click": "swaync-client -t -sw",
	"on-click-right": "swaync-client -d -sw",
	"escape": true
   },
   //´őÖ,´őÜ,´őŚ,´őľ,´őĽ,´őŤ,´őÜ,´őť,´őŁ,´ő×
    "custom/gpu": {
        "tooltip": false,
	"format": "  GPU: {}% ´őŤ",
	"interval": 10,
	"exec": "nvidia-smi --query-gpu=utilization.gpu --format=csv | grep -G [0-9] -o",
    	"exec-if": "exit 0"
    },
    "custom/gputemp": {
        "tooltip": false,
	"format": "   {}┬░C ´Łę",
	"interval": 10,
	"exec": "nvidia-smi --query-gpu=temperature.gpu --format=csv | grep -G [0-9] -o | tr -d '\n'",
    	"exec-if": "exit 0"
    },
    "custom/power": {
        "tooltip": false,
	"format": "   {}",
	"interval": 2,
	"exec": "asusctl profile -p | grep -E 'Quiet|Balanced|Performance' -o",
    	"exec-if": "exit 0"
    }


}
